#!/bin/bash
# =============================================================================
# 完整的服务诊断和测试脚本 - 详细中文注释版本
# =============================================================================
# 功能说明：
#   对 ceph-exporter 及其相关服务进行全面诊断和测试
#
# 主要功能：
#   1. 检查容器运行状态
#   2. 检查 Elasticsearch 健康状态和索引
#   3. 检查 ceph-exporter 健康状态
#   4. 检查 Logstash 和 Jaeger 状态
#   5. 生成测试数据并验证日志流转
#   6. 输出诊断总结和故障排查建议
#
# 使用方式：
#   ./scripts/diagnose-and-test.sh
#
# 注意事项：
#   - 需要 docker 命令可用
#   - 测试过程包含等待时间（约 30 秒）
#   - 需要 curl 命令可用
# =============================================================================

# -----------------------------------------------------------------------------
# Bash 严格模式设置
# -----------------------------------------------------------------------------
# set -e: 任何命令失败时立即退出
set -e

# -----------------------------------------------------------------------------
# 切换到部署目录
# -----------------------------------------------------------------------------
# 动态获取脚本所在目录，然后切换到上级目录（deployments/）
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."

# -----------------------------------------------------------------------------
# 显示脚本标题
# -----------------------------------------------------------------------------
echo "╔══════════════════════════════════════════════════════════════════════════╗"
echo "║              服务诊断和测试                                               ║"
echo "╚══════════════════════════════════════════════════════════════════════════╝"
echo ""

# -----------------------------------------------------------------------------
# 第 1 步：检查容器状态
# -----------------------------------------------------------------------------
# 使用 docker ps 查看所有容器的名称和状态
echo "[1/10] 检查容器状态..."
docker ps --format "table {{.Names}}\t{{.Status}}"
echo ""

# -----------------------------------------------------------------------------
# 第 2 步：检查 Elasticsearch 健康状态
# -----------------------------------------------------------------------------
# 通过 _cluster/health API 检查集群健康
echo "[2/10] 检查 Elasticsearch 健康状态..."
if curl -s http://localhost:9200/_cluster/health?pretty; then
    echo "✅ Elasticsearch 正常"
else
    echo "❌ Elasticsearch 未响应"
    echo "查看日志:"
    # --tail 20: 只显示最后 20 行日志
    docker logs elasticsearch --tail 20
fi
echo ""

# -----------------------------------------------------------------------------
# 第 3 步：检查 Elasticsearch 索引
# -----------------------------------------------------------------------------
# 通过 _cat/indices API 列出所有索引
echo "[3/10] 检查 Elasticsearch 索引..."
curl -s http://localhost:9200/_cat/indices?v || echo "❌ 无法获取索引列表"
echo ""

# -----------------------------------------------------------------------------
# 第 4 步：检查 ceph-exporter 状态
# -----------------------------------------------------------------------------
# 通过 /health 端点检查 ceph-exporter 是否正常
echo "[4/10] 检查 ceph-exporter 状态..."
if curl -s http://localhost:9128/health > /dev/null 2>&1; then
    echo "✅ ceph-exporter 正常"
else
    echo "❌ ceph-exporter 未响应"
    echo "查看日志:"
    docker logs ceph-exporter --tail 20
fi
echo ""

# -----------------------------------------------------------------------------
# 第 5 步：检查 Logstash 状态
# -----------------------------------------------------------------------------
# 从 Logstash 日志中查找管道启动信息或错误
echo "[5/10] 检查 Logstash 状态..."
docker logs logstash --tail 10 | grep -E "Pipeline started|error" || echo "查看完整日志"
echo ""

# -----------------------------------------------------------------------------
# 第 6 步：检查 Jaeger 状态
# -----------------------------------------------------------------------------
# 通过访问 Jaeger UI 端口判断服务是否可用
echo "[6/10] 检查 Jaeger 状态..."
if curl -s http://localhost:16686 > /dev/null 2>&1; then
    echo "✅ Jaeger 正常"
else
    echo "❌ Jaeger 未响应"
fi
echo ""

# -----------------------------------------------------------------------------
# 第 7 步：生成测试数据
# -----------------------------------------------------------------------------
# 向 ceph-exporter 发送 10 个请求以生成 metrics 数据
echo "[7/10] 生成测试数据..."
echo "发送 10 个请求到 ceph-exporter..."
for i in {1..10}; do
    if curl -s http://localhost:9128/metrics > /dev/null 2>&1; then
        echo "  请求 $i - 成功"
    else
        echo "  请求 $i - 失败"
    fi
    # 每个请求间隔 1 秒，避免过于频繁
    sleep 1
done
echo ""

# -----------------------------------------------------------------------------
# 第 8 步：等待日志推送
# -----------------------------------------------------------------------------
# 等待 10 秒让 Logstash 将日志推送到 Elasticsearch
echo "[8/10] 等待日志推送到 Elasticsearch (10秒)..."
sleep 10
echo ""

# -----------------------------------------------------------------------------
# 第 9 步：再次检查 Elasticsearch 索引
# -----------------------------------------------------------------------------
# 验证测试数据是否已写入 Elasticsearch
echo "[9/10] 再次检查 Elasticsearch 索引..."
curl -s http://localhost:9200/_cat/indices?v || echo "❌ 无法获取索引列表"
echo ""

# -----------------------------------------------------------------------------
# 第 10 步：查询日志数据
# -----------------------------------------------------------------------------
# 从 Elasticsearch 中查询 ceph-exporter 的日志数据
echo "[10/10] 查询日志数据..."
if curl -s "http://localhost:9200/ceph-exporter-*/_search?size=1&pretty" | head -30; then
    echo "✅ 找到日志数据"
else
    echo "❌ 未找到日志数据"
fi
echo ""

# -----------------------------------------------------------------------------
# 诊断总结
# -----------------------------------------------------------------------------
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " 诊断总结"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# 检查各个服务的状态
# 使用 curl 检测各服务端口，输出状态图标
ES_STATUS=$(curl -s http://localhost:9200/_cluster/health 2>&1 | grep -q "status" && echo "✅" || echo "❌")
CEPH_STATUS=$(curl -s http://localhost:9128/health 2>&1 > /dev/null && echo "✅" || echo "❌")
JAEGER_STATUS=$(curl -s http://localhost:16686 2>&1 > /dev/null && echo "✅" || echo "❌")
KIBANA_STATUS=$(curl -s http://localhost:5601 2>&1 > /dev/null && echo "✅" || echo "❌")

# 输出服务状态汇总表
echo "服务状态:"
echo "  Elasticsearch: $ES_STATUS"
echo "  ceph-exporter: $CEPH_STATUS"
echo "  Jaeger:        $JAEGER_STATUS"
echo "  Kibana:        $KIBANA_STATUS"
echo ""

# 输出各服务的访问地址
echo "访问地址:"
echo "  Kibana:  http://localhost:5601"
echo "  Jaeger:  http://localhost:16686"
echo "  ceph-exporter: http://localhost:9128"
echo ""

# -----------------------------------------------------------------------------
# 故障排查建议
# -----------------------------------------------------------------------------
# 如果 Elasticsearch 未运行，给出排查建议
if [ "$ES_STATUS" = "❌" ]; then
    echo "⚠️  Elasticsearch 未运行，请检查:"
    echo "  1. docker logs elasticsearch"
    echo "  2. 确认权限已修复: sudo chown -R 1000:1000 data/elasticsearch"
    echo "  3. 重启: docker compose -f docker-compose-lightweight-full.yml restart elasticsearch"
fi

# 如果 ceph-exporter 未运行，给出排查建议
if [ "$CEPH_STATUS" = "❌" ]; then
    echo "⚠️  ceph-exporter 未运行，请检查:"
    echo "  1. docker logs ceph-exporter"
    echo "  2. 确认 Ceph 配置存在: ls -la data/ceph-demo/config/"
    echo "  3. 重启: docker compose -f docker-compose-lightweight-full.yml restart ceph-exporter"
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════════════════╗"
echo "║                    诊断完成                                               ║"
echo "╚══════════════════════════════════════════════════════════════════════════╝"
