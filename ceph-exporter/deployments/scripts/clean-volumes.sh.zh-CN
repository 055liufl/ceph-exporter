#!/bin/bash
# =============================================================================
# Ceph 数据目录彻底清理脚本 - 详细中文注释版本
# =============================================================================
# 功能说明：
#   彻底清理 Ceph 数据目录，用于解决数据损坏或配置错误问题
#
# 工作流程：
#   1. 停止所有相关服务（Ceph Demo、完整监控栈、集成测试等）
#   2. 删除 ./data/ 目录中的所有持久化数据
#   3. 重新初始化数据目录结构
#   4. 重新启动 Ceph Demo 服务
#   5. 等待 Ceph 集群初始化（约 5 分钟）
#   6. 检查容器状态和 Ceph 集群健康状况
#
# 使用场景：
#   - Ceph Demo 无法正常启动
#   - Ceph 集群状态异常（HEALTH_ERR）
#   - 需要完全重置 Ceph 环境
#   - 数据目录中有损坏的文件
#
# 注意事项：
#   - 此操作会删除所有 Ceph 数据，无法恢复！
#   - 现在使用绑定挂载，数据存储在 ./data/ 目录
#   - 建议使用 ./deploy.sh clean 命令代替此脚本
#   - 需要等待约 5 分钟让 Ceph 重新初始化
# =============================================================================

# -----------------------------------------------------------------------------
# Bash 严格模式
# -----------------------------------------------------------------------------
# set -e: 遇到错误立即退出
set -e

# -----------------------------------------------------------------------------
# 目录路径定义
# -----------------------------------------------------------------------------
# SCRIPT_DIR: 当前脚本所在目录的绝对路径
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# DEPLOY_DIR: 部署配置目录（脚本目录的上级目录）
DEPLOY_DIR="$(dirname "$SCRIPT_DIR")"

# -----------------------------------------------------------------------------
# 显示操作说明和警告
# -----------------------------------------------------------------------------
echo "=========================================="
echo "彻底清理 Ceph 数据目录"
echo "=========================================="
echo ""
echo "此脚本将:"
echo "  1. 停止所有服务"
echo "  2. 删除 ./data/ 目录中的所有数据"
echo "  3. 重新初始化数据目录"
echo "  4. 重新启动 Ceph Demo"
echo ""
echo "⚠️  警告: 这将删除所有持久化数据！"
echo ""

# 要求用户明确确认
# 必须输入 "yes" 才能继续（而不是 y/Y），防止误操作
read -p "确认继续? (输入 yes): " confirm

# 检查用户输入是否为 "yes"
if [ "$confirm" != "yes" ]; then
    echo "操作已取消"
    exit 0
fi

# 切换到部署目录
# 所有 docker compose 配置文件都在这个目录
cd "$DEPLOY_DIR"

# -----------------------------------------------------------------------------
# 步骤 1: 停止所有服务
# -----------------------------------------------------------------------------
echo ""
echo "步骤 1: 停止所有服务..."
# 依次停止各个 compose 配置的服务
# 2>/dev/null: 忽略错误输出（如果服务未运行）
# || true: 即使失败也继续执行（确保后续步骤不受影响）
docker compose -f docker-compose-ceph-demo.yml down 2>/dev/null || true
docker compose -f docker-compose-lightweight-full.yml down 2>/dev/null || true
docker compose -f docker-compose-integration-test.yml down 2>/dev/null || true
docker compose down 2>/dev/null || true

# -----------------------------------------------------------------------------
# 步骤 2: 删除数据目录
# -----------------------------------------------------------------------------
echo ""
echo "步骤 2: 删除数据目录..."
if [ -d "data" ]; then
    echo "删除 data/ 目录..."
    # rm -rf: 递归强制删除，不提示确认
    rm -rf data/
    echo "✓ 数据目录已删除"
else
    echo "数据目录不存在，跳过"
fi

# -----------------------------------------------------------------------------
# 步骤 3: 重新初始化数据目录
# -----------------------------------------------------------------------------
echo ""
echo "步骤 3: 重新初始化数据目录..."
# 调用 deploy.sh 的 init 子命令重建目录结构和权限
./scripts/deploy.sh init

# -----------------------------------------------------------------------------
# 步骤 4: 启动 Ceph Demo
# -----------------------------------------------------------------------------
echo ""
echo "步骤 4: 启动 Ceph Demo..."
# -d: 后台运行（detached mode）
docker compose -f docker-compose-ceph-demo.yml up -d

# -----------------------------------------------------------------------------
# 步骤 5: 等待 Ceph 初始化
# -----------------------------------------------------------------------------
echo ""
echo "步骤 5: 等待 Ceph 初始化（5 分钟）..."
# 循环 300 次，每次 1 秒，总共等待 5 分钟
# Ceph 需要时间创建 Monitor、OSD、MDS 等组件
for i in {1..300}; do
    # -n: 不换行，持续在同一行输出进度点
    echo -n "."
    sleep 1
    # 每 30 秒显示一次进度
    # $((i % 30)): 计算 i 除以 30 的余数
    # -eq 0: 等于 0 时（即每 30 秒）显示已等待秒数
    if [ $((i % 30)) -eq 0 ]; then
        echo " ${i}秒"
    fi
done
echo ""

# -----------------------------------------------------------------------------
# 步骤 6: 检查容器状态
# -----------------------------------------------------------------------------
echo ""
echo "步骤 6: 检查状态..."
# --filter name=ceph-demo: 只显示名称包含 ceph-demo 的容器
docker ps --filter name=ceph-demo

# -----------------------------------------------------------------------------
# 步骤 7: 查看容器日志
# -----------------------------------------------------------------------------
echo ""
echo "步骤 7: 查看日志..."
# --tail 50: 只显示最后 50 行日志
docker logs ceph-demo --tail 50

# -----------------------------------------------------------------------------
# 步骤 8: 测试 Ceph 集群状态
# -----------------------------------------------------------------------------
echo ""
echo "步骤 8: 测试 Ceph..."
# timeout 30: 最多等待 30 秒
# docker exec: 在运行的容器中执行命令
# ceph -s: 查看 Ceph 集群状态（正常应显示 HEALTH_OK）
# 2>&1: 将标准错误合并到标准输出
# || echo "...": 如果命令超时或失败，显示警告
timeout 30 docker exec ceph-demo ceph -s 2>&1 || echo "⚠️  Ceph 命令超时"

# -----------------------------------------------------------------------------
# 完成提示
# -----------------------------------------------------------------------------
echo ""
echo "=========================================="
echo "清理完成"
echo "=========================================="
echo ""
echo "数据存储位置: $DEPLOY_DIR/data/"
echo "查看数据: ls -lh data/"
