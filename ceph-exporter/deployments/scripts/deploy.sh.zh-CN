# -----------------------------------------------------------------------------
# 服务管理函数
# -----------------------------------------------------------------------------

# 查看服务状态
# 说明：
#   - 自动检测使用的配置文件
#   - 显示所有容器的状态
show_status() {
    log_step "服务状态:"

    cd "$DEPLOY_DIR"

    # 检查是否有运行中的 compose 项目
    # docker ps --format: 自定义输出格式
    # com.docker.compose.project: compose 项目标签
    if docker ps --format '{{.Label "com.docker.compose.project"}}' | grep -q "deployments"; then
        # 根据运行的容器判断使用的配置文件
        if docker ps --format '{{.Names}}' | grep -q "kibana"; then
            # 包含 kibana 说明是完整栈
            ${COMPOSE_CMD} -f docker-compose-lightweight-full.yml ps
        elif docker ps --format '{{.Names}}' | grep -q "ceph-demo"; then
            # 包含 ceph-demo 说明是集成测试环境
            ${COMPOSE_CMD} -f docker-compose-integration-test.yml ps
        else
            # 否则是最小栈
            ${COMPOSE_CMD} -f docker-compose.yml ps
        fi
    else
        log_warn "未检测到运行中的服务"
        # 显示所有容器
        docker ps
    fi
}

# 查看服务日志
# 说明：
#   - 可以查看所有服务或指定服务的日志
#   - 使用 -f 参数实时跟踪日志
# 参数：
#   $1 - 可选，指定服务名称
show_logs() {
    cd "$DEPLOY_DIR"

    # 获取服务名称参数（如果有）
    local service="${1:-}"

    # 自动检测使用的配置文件
    local compose_file="docker-compose.yml"
    if docker ps --format '{{.Names}}' | grep -q "kibana"; then
        compose_file="docker-compose-lightweight-full.yml"
    elif docker ps --format '{{.Names}}' | grep -q "ceph-demo"; then
        compose_file="docker-compose-integration-test.yml"
    fi

    # 如果指定了服务名，只查看该服务的日志
    if [ -n "$service" ]; then
        ${COMPOSE_CMD} -f "$compose_file" logs -f "$service"
    else
        # 否则查看所有服务的日志
        ${COMPOSE_CMD} -f "$compose_file" logs -f
    fi
}

# 验证部署状态
# 说明：
#   - 检查各服务的健康检查端点
#   - 使用 curl 测试服务是否可访问
verify_deployment() {
    log_step "验证部署状态..."

    # 定义基础服务列表（服务名:端口/路径）
    local services=(
        "ceph-exporter:9128/health"      # ceph-exporter 健康检查
        "prometheus:9090/-/healthy"      # Prometheus 健康检查
        "grafana:3000/api/health"        # Grafana 健康检查
    )

    # 如果部署了完整栈，添加额外的服务
    if docker ps --format '{{.Names}}' | grep -q "elasticsearch"; then
        services+=(
            "elasticsearch:9200"         # Elasticsearch API
            "kibana:5601/api/status"     # Kibana 状态
            "jaeger:16686"               # Jaeger UI
        )
    fi

    # 如果部署了 Ceph Demo，添加 Ceph 服务
    if docker ps --format '{{.Names}}' | grep -q "ceph-demo"; then
        services+=("ceph-demo:8080")     # Ceph Dashboard
    fi

    echo ""
    # 遍历服务列表，逐个检查
    for service in "${services[@]}"; do
        # 分割服务名和端点
        local name="${service%%:*}"      # 提取冒号前的部分（服务名）
        local endpoint="${service#*:}"   # 提取冒号后的部分（端点）

        log_info "检查 ${name}..."

        # 使用 curl 测试端点
        # -s: 静默模式
        # -f: 失败时返回非零状态码
        # > /dev/null 2>&1: 丢弃所有输出
        if curl -sf "http://localhost:${endpoint}" > /dev/null 2>&1; then
            echo -e "${GREEN}✓${NC} ${name} 运行正常"
        else
            echo -e "${YELLOW}✗${NC} ${name} 无法访问或尚未就绪"
        fi
    done
    echo ""
}

# 停止所有服务
# 说明：
#   - 停止所有可能运行的配置
#   - 不删除数据卷
stop_services() {
    log_step "停止服务..."

    cd "$DEPLOY_DIR"

    # 遍历所有配置文件，逐个停止
    for compose_file in docker-compose.yml docker-compose-integration-test.yml docker-compose-lightweight-full.yml; do
        if [ -f "$compose_file" ]; then
            # down: 停止并删除容器、网络
            # 2>/dev/null: 忽略错误（文件可能未运行）
            # || true: 即使失败也继续执行
            ${COMPOSE_CMD} -f "$compose_file" down 2>/dev/null || true
        fi
    done

    log_info "所有服务已停止"
}

# 清理数据卷
# 说明：
#   - 停止服务并删除所有持久化数据
#   - 需要用户确认（防止误操作）
clean_data() {
    log_warn "此操作将停止所有服务并删除持久化数据"
    log_warn "包括: Prometheus 数据、Grafana 配置、Elasticsearch 索引等"

    # 要求用户确认
    read -p "确认继续? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "操作已取消"
        exit 0
    fi

    log_step "停止服务并清除数据卷..."

    cd "$DEPLOY_DIR"

    # 停止并删除所有配置的容器和数据卷
    for compose_file in docker-compose.yml docker-compose-integration-test.yml docker-compose-lightweight-full.yml; do
        if [ -f "$compose_file" ]; then
            # -v: 同时删除数据卷
            ${COMPOSE_CMD} -f "$compose_file" down -v 2>/dev/null || true
        fi
    done

    log_info "所有服务已停止，数据卷已清除"
}

# -----------------------------------------------------------------------------
# 帮助信息
# -----------------------------------------------------------------------------

# 显示帮助信息
show_help() {
    cat << 'EOF'
ceph-exporter 部署脚本

用法:
  ./deploy.sh <command>

命令:
  check           检查系统环境（Docker、资源、防火墙等）
  mirror          配置 Docker 镜像加速器
  pull            预拉取所有镜像
  minimal         部署最小监控栈
  integration     部署集成测试环境
  full            部署完整轻量级栈（推荐）
  status          查看服务状态
  logs [service]  查看日志（可指定服务名）
  verify          验证部署状态
  stop            停止所有服务
  clean           停止服务并清除数据卷
  help            显示此帮助信息

示例:
  # 完整部署（推荐）
  ./deploy.sh full

  # 检查环境
  ./deploy.sh check

  # 查看服务状态
  ./deploy.sh status

  # 查看特定服务日志
  ./deploy.sh logs ceph-exporter

  # 验证部署
  ./deploy.sh verify
EOF
}

# -----------------------------------------------------------------------------
# 完整环境检查
# -----------------------------------------------------------------------------

# 执行所有环境检查
full_check() {
    check_root
    check_os
    check_docker
    check_docker_compose
    check_resources
    check_firewall
    check_selinux

    log_info "环境检查完成"
}

# -----------------------------------------------------------------------------
# 主函数
# -----------------------------------------------------------------------------

# 主函数 - 根据命令参数执行相应操作
# 参数：
#   $1 - 命令名称（check/mirror/pull/minimal/integration/full/status/logs/verify/stop/clean/help）
main() {
    # ${1:-help}: 如果没有参数，默认为 help
    case "${1:-help}" in
        check)
            # 只检查环境，不部署
            full_check
            ;;
        mirror)
            # 只配置镜像加速
            check_docker
            configure_mirror
            ;;
        pull)
            # 只拉取镜像
            check_docker
            check_docker_compose
            pull_images
            ;;
        minimal)
            # 部署最小栈
            full_check
            configure_mirror
            deploy_minimal
            verify_deployment
            ;;
        integration)
            # 部署集成测试环境
            full_check
            configure_mirror
            pull_images
            deploy_integration
            verify_deployment
            ;;
        full)
            # 部署完整栈（推荐）
            full_check
            configure_mirror
            pull_images
            deploy_full
            verify_deployment
            ;;
        status)
            # 查看状态
            check_docker_compose
            show_status
            ;;
        logs)
            # 查看日志
            check_docker_compose
            shift  # 移除第一个参数
            show_logs "$@"  # 传递剩余参数
            ;;
        verify)
            # 验证部署
            verify_deployment
            ;;
        stop)
            # 停止服务
            check_docker_compose
            stop_services
            ;;
        clean)
            # 清理数据
            check_docker_compose
            clean_data
            ;;
        help|*)
            # 显示帮助或未知命令
            show_help
            ;;
    esac
}

# 执行主函数，传递所有命令行参数
main "$@"
