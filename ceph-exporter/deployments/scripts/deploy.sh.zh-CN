# -----------------------------------------------------------------------------
# 服务管理函数
# -----------------------------------------------------------------------------

# 查看服务状态
# 说明：
#   - 自动检测当前运行的 compose 配置
#   - 根据运行的容器名称判断使用的配置文件
#   - 显示所有容器的状态
show_status() {
    log_step "服务状态:"

    cd "$DEPLOY_DIR"

    # 尝试查找正在运行的 compose 文件
    # docker ps --format: 自定义输出格式
    # com.docker.compose.project: compose 项目标签
    if docker ps --format '{{.Label "com.docker.compose.project"}}' | grep -q "deployments"; then
        # 检测使用的 compose 文件
        # 根据运行的容器名判断部署模式
        if docker ps --format '{{.Names}}' | grep -q "kibana"; then
            # 包含 kibana 说明是完整栈
            ${COMPOSE_CMD} -f docker-compose-lightweight-full.yml ps
        elif docker ps --format '{{.Names}}' | grep -q "ceph-demo"; then
            # 包含 ceph-demo 说明是集成测试环境
            ${COMPOSE_CMD} -f docker-compose-integration-test.yml ps
        else
            # 否则是最小栈
            ${COMPOSE_CMD} -f docker-compose.yml ps
        fi
    else
        log_warn "未检测到运行中的服务"
        # 显示所有容器
        docker ps
    fi
}

# 查看服务日志
# 说明：
#   - 可以查看所有服务或指定服务的日志
#   - 使用 -f 参数实时跟踪日志
#   - 自动检测使用的配置文件
# 参数：
#   $1 - 可选，指定服务名称
show_logs() {
    cd "$DEPLOY_DIR"

    # 获取服务名称参数（如果有）
    local service="${1:-}"

    # 检测使用的 compose 文件
    # 自动检测当前使用的配置文件
    local compose_file="docker-compose.yml"
    if docker ps --format '{{.Names}}' | grep -q "kibana"; then
        compose_file="docker-compose-lightweight-full.yml"
    elif docker ps --format '{{.Names}}' | grep -q "ceph-demo"; then
        compose_file="docker-compose-integration-test.yml"
    fi

    # 如果指定了服务名，只查看该服务的日志
    if [ -n "$service" ]; then
        ${COMPOSE_CMD} -f "$compose_file" logs -f "$service"
    else
        # 否则查看所有服务的日志
        ${COMPOSE_CMD} -f "$compose_file" logs -f
    fi
}

# 验证部署状态
# 说明：
#   - 检查各服务的健康检查端点
#   - 使用 curl 测试服务是否可访问
#   - 自动检测已部署的服务并验证
#   - 同时验证容器时区配置是否与宿主机一致
verify_deployment() {
    log_step "验证部署状态..."

    # 定义基础服务列表（服务名:端口/路径）
    local services=(
        "ceph-exporter:9128/health"
        "prometheus:9090/-/healthy"
        "grafana:3000/api/health"
    )

    # 检查是否部署了完整栈
    # 如果有 elasticsearch 容器运行，说明是完整栈，添加额外服务检查
    if docker ps --format '{{.Names}}' | grep -q "elasticsearch"; then
        services+=(
            "elasticsearch:9200"
            "kibana:5601/api/status"
            "jaeger:16686"
        )
    fi

    # 检查是否部署了 Ceph Demo
    if docker ps --format '{{.Names}}' | grep -q "ceph-demo"; then
        services+=("ceph-demo:8080")
    fi

    echo ""
    # 遍历服务列表，逐个检查
    for service in "${services[@]}"; do
        # 分割服务名和端点
        # ${service%%:*}: 提取冒号前的部分（服务名）
        # ${service#*:}: 提取冒号后的部分（端点）
        local name="${service%%:*}"
        local endpoint="${service#*:}"

        log_info "检查 ${name}..."

        # 特殊处理 ceph-demo：RGW 根路径返回 404 是正常的
        # 说明：Ceph RGW 的根路径会返回 NoSuchBucket 或 InvalidBucketName，这是正常行为
        if [ "$name" = "ceph-demo" ]; then
            if curl -s "http://localhost:${endpoint}" 2>&1 | grep -q "NoSuchBucket\|InvalidBucketName\|404"; then
                echo -e "${GREEN}✓${NC} ${name} 运行正常"
            else
                echo -e "${YELLOW}✗${NC} ${name} 无法访问或尚未就绪"
            fi
        else
            # 使用 curl 测试端点
            # -s: 静默模式
            # -f: 失败时返回非零状态码
            # > /dev/null 2>&1: 丢弃所有输出
            if curl -sf "http://localhost:${endpoint}" > /dev/null 2>&1; then
                echo -e "${GREEN}✓${NC} ${name} 运行正常"
            else
                echo -e "${YELLOW}✗${NC} ${name} 无法访问或尚未就绪"
            fi
        fi
    done
    echo ""

    # 验证时区配置
    # 说明：检查容器时区是否与宿主机一致，确保日志和指标时间戳正确
    log_info "验证容器时区配置..."
    if docker ps --format '{{.Names}}' | grep -q "ceph-exporter"; then
        local host_tz=$(date +"%Z %z")
        local container_tz=$(docker exec ceph-exporter date +"%Z %z" 2>/dev/null || echo "无法获取")
        if [ "$host_tz" = "$container_tz" ]; then
            echo -e "${GREEN}✓${NC} 容器时区与宿主机一致: $host_tz"
        else
            echo -e "${YELLOW}!${NC} 宿主机时区: $host_tz, 容器时区: $container_tz"
        fi
    fi
    echo ""
}

# 停止所有服务
# 说明：
#   - 停止所有可能运行的配置
#   - 遍历所有 compose 文件逐个停止
#   - 不删除数据目录
stop_services() {
    log_step "停止服务..."

    cd "$DEPLOY_DIR"

    # 检测并停止所有可能运行的 compose 配置
    # 遍历所有配置文件，逐个停止
    for compose_file in docker-compose.yml docker-compose-integration-test.yml docker-compose-lightweight-full.yml docker-compose-ceph-demo.yml; do
        if [ -f "$compose_file" ]; then
            # down: 停止并删除容器、网络
            # 2>/dev/null: 忽略错误（文件可能未运行）
            # || true: 即使失败也继续执行
            ${COMPOSE_CMD} -f "$compose_file" down 2>/dev/null || true
        fi
    done

    log_info "所有服务已停止"
}

# 清理数据
# 说明：
#   - 停止所有服务并删除持久化数据目录
#   - 需要用户确认（防止误操作）
#   - 包括 Prometheus 数据、Grafana 配置、Elasticsearch 索引等
clean_data() {
    log_warn "此操作将停止所有服务并删除持久化数据"
    # 要求用户确认
    read -p "确认继续? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "操作已取消"
        exit 0
    fi

    log_step "停止服务并清除数据..."

    cd "$DEPLOY_DIR"

    # 停止所有服务
    for compose_file in docker-compose.yml docker-compose-integration-test.yml docker-compose-lightweight-full.yml docker-compose-ceph-demo.yml; do
        if [ -f "$compose_file" ]; then
            ${COMPOSE_CMD} -f "$compose_file" down 2>/dev/null || true
        fi
    done

    # 删除数据目录
    if [ -d "data" ]; then
        log_info "删除数据目录..."
        rm -rf data/
        log_info "数据目录已删除"
    fi

    log_info "所有服务已停止，数据卷已清除"
}

# -----------------------------------------------------------------------------
# 帮助信息
# -----------------------------------------------------------------------------

# 显示帮助信息
# 说明：显示所有可用命令、别名和使用示例
show_help() {
    print_banner
    cat << 'EOF'

用法:
  ./deploy.sh <命令>

命令:
  check           检查系统环境（Docker、资源、防火墙等）
  mirror          配置 Docker 镜像加速器
  pull            预拉取所有镜像
  init            初始化数据目录（创建目录并设置权限）
  minimal         部署最小监控栈（标准部署，需要现有 Ceph 集群）
  integration     部署集成测试环境（包含 Ceph Demo）
  full            部署完整轻量级栈（包含 Ceph Demo + ELK + Jaeger，推荐）
  status          查看服务状态
  logs [service]  查看日志（可指定服务名）
  verify          验证部署状态
  diagnose [svc]  诊断服务问题（可指定服务名或 all）
  fix             修复常见部署问题（权限、配置等）
  stop            停止所有服务
  clean           停止服务并清除数据
  help            显示此帮助信息

别名（为了兼容性）:
  standard        等同于 minimal（标准部署）
  test            等同于 integration（集成测试）

示例:
  # 完整部署（推荐，包含中文界面）
  ./deploy.sh full

  # 完整部署 - 指定日志方案（跳过交互选择）
  LOGGING_MODE=container ./deploy.sh full     # 容器日志收集（推荐）
  LOGGING_MODE=direct ./deploy.sh full        # 直接推送到 Logstash (TCP)
  LOGGING_MODE=direct-udp ./deploy.sh full    # 直接推送到 Logstash (UDP)
  LOGGING_MODE=file ./deploy.sh full          # 文件日志 + Filebeat
  LOGGING_MODE=dev ./deploy.sh full           # 开发模式

  # 标准部署（连接现有 Ceph 集群）
  ./deploy.sh minimal
  # 或
  ./deploy.sh standard

  # 集成测试环境
  ./deploy.sh integration
  # 或
  ./deploy.sh test

  # 检查环境
  ./deploy.sh check

  # 查看服务状态
  ./deploy.sh status

  # 查看特定服务日志
  ./deploy.sh logs ceph-exporter

  # 完整诊断
  ./deploy.sh diagnose

  # 诊断特定服务
  ./deploy.sh diagnose ceph-exporter

  # 验证部署
  ./deploy.sh verify

  # 修复部署问题
  ./deploy.sh fix

中文界面支持:
  所有部署模式都已配置中文界面，包括：
  - Grafana 监控仪表盘（中文界面和 Dashboard）
  - Prometheus 告警规则（中文描述）
  - Alertmanager 告警管理（中文配置）
  - Kibana 日志分析（中文界面支持）

故障排查:
  如果遇到部署问题，请查看:
  - 故障排查指南: cat TROUBLESHOOTING.md
  - 运行修复脚本: ./deploy.sh fix
  - 查看服务日志: ./deploy.sh logs <service-name>
EOF
}

# -----------------------------------------------------------------------------
# 完整环境检查
# -----------------------------------------------------------------------------

# 执行所有环境检查
# 说明：依次调用所有检查函数，完成全面的环境验证
full_check() {
    check_root
    check_os
    check_docker
    check_docker_compose
    check_resources
    check_firewall
    check_selinux

    log_info "环境检查完成"
}

# -----------------------------------------------------------------------------
# 主函数
# -----------------------------------------------------------------------------

# 主函数 - 根据命令参数执行相应操作
# 参数：
#   $1 - 命令名称（check/mirror/pull/init/minimal/standard/integration/test/full/status/logs/verify/diagnose/fix/stop/clean/help）
# 主函数
main() {
    # ${1:-help}: 如果没有参数，默认为 help
    case "${1:-help}" in
        check)
            # 只检查环境，不部署
            full_check
            ;;
        mirror)
            # 只配置镜像加速
            check_docker
            configure_mirror
            ;;
        pull)
            # 只拉取镜像
            check_docker
            check_docker_compose
            pull_images
            ;;
        init)
            # 只初始化数据目录
            init_data_dirs
            ;;
        minimal|standard)
            # 部署最小栈（standard 是 minimal 的别名）
            full_check
            configure_mirror
            deploy_minimal
            verify_deployment
            ;;
        integration|test)
            # 部署集成测试环境（test 是 integration 的别名）
            full_check
            configure_mirror
            pull_images
            deploy_integration
            verify_deployment
            ;;
        full)
            # 部署完整栈（推荐）
            full_check
            configure_mirror
            pull_images
            deploy_full
            verify_deployment
            ;;
        status)
            # 查看状态
            check_docker_compose
            show_status
            ;;
        logs)
            # 查看日志
            check_docker_compose
            shift
            show_logs "$@"
            ;;
        verify)
            # 验证部署
            verify_deployment
            ;;
        diagnose)
            # 诊断服务问题
            # 说明：调用独立的诊断脚本，支持指定服务名或 all
            shift
            log_info "运行诊断脚本..."
            exec "$SCRIPT_DIR/diagnose.sh" "$@"
            ;;
        fix)
            # 修复常见部署问题
            # 说明：调用独立的修复脚本，自动修复权限、配置等问题
            log_info "运行修复脚本..."
            exec "$SCRIPT_DIR/fix-deployment.sh"
            ;;
        stop)
            # 停止服务
            check_docker_compose
            stop_services
            ;;
        clean)
            # 清理数据
            check_docker_compose
            clean_data
            ;;
        help|*)
            # 显示帮助或未知命令
            show_help
            ;;
    esac
}

# 执行主函数，传递所有命令行参数
# "$@": 所有命令行参数（保持原始引号和空格）
main "$@"
