#!/bin/bash
# =============================================================================
# 临时文件清理脚本 - 详细中文注释版本
# =============================================================================
# 功能说明：
#   清理 ELK 集成过程中产生的临时文件
#
# 主要功能：
#   1. 清理 /tmp 目录下的临时文件（elk-*.txt、logstash-*.txt、network-*.txt）
#   2. 清理临时文档（如 LOGSTASH-VERIFICATION-SUCCESS.md）
#   3. 交互式询问是否删除备份文件（.bak）
#
# 使用方式：
#   ./scripts/cleanup-temp-files.sh            # 显示警告提示
#   ./scripts/cleanup-temp-files.sh --confirm  # 确认后执行清理
#
# 注意事项：
#   - 必须使用 --confirm 参数才会执行清理操作
#   - 建议先运行 list-temp-files.sh 查看将要删除的文件
#   - 备份文件删除前会交互式确认
# =============================================================================

# -----------------------------------------------------------------------------
# 终端颜色定义
# -----------------------------------------------------------------------------
RED='\033[0;31m'      # 红色 - 警告/错误信息
GREEN='\033[0;32m'    # 绿色 - 成功信息
YELLOW='\033[1;33m'   # 黄色 - 提示信息
NC='\033[0m'          # 无颜色 - 重置

# -----------------------------------------------------------------------------
# 安全检查：确认是否传入 --confirm 参数
# -----------------------------------------------------------------------------
# 如果没有 --confirm 参数，显示警告并退出
if [ "$1" != "--confirm" ]; then
    echo -e "${RED}警告: 此脚本将删除临时文件${NC}"
    echo ""
    echo "请先运行以下命令查看将要删除的文件:"
    echo "  ./scripts/list-temp-files.sh"
    echo ""
    echo "确认后，使用 --confirm 参数运行:"
    echo "  ./scripts/cleanup-temp-files.sh --confirm"
    echo ""
    exit 1
fi

# -----------------------------------------------------------------------------
# 开始清理流程
# -----------------------------------------------------------------------------
echo -e "${YELLOW}开始清理临时文件...${NC}"
echo ""

# -----------------------------------------------------------------------------
# 第 1 步：清理 /tmp 临时文件
# -----------------------------------------------------------------------------
# 删除 /tmp 目录下由诊断脚本生成的临时文件
echo "[1/3] 清理 /tmp 临时文件..."
rm -f /tmp/elk-*.txt /tmp/logstash-*.txt /tmp/network-*.txt 2>/dev/null
# $? 检查上一条命令的退出状态码，0 表示成功
if [ $? -eq 0 ]; then
    echo -e "${GREEN}✓ /tmp 临时文件已清理${NC}"
else
    echo -e "${YELLOW}⚠ 没有找到 /tmp 临时文件${NC}"
fi
echo ""

# -----------------------------------------------------------------------------
# 第 2 步：清理临时文档
# -----------------------------------------------------------------------------
# 删除 ELK 验证过程中生成的临时文档
echo "[2/3] 清理临时文档..."
if [ -f "deployments/LOGSTASH-VERIFICATION-SUCCESS.md" ]; then
    rm -f deployments/LOGSTASH-VERIFICATION-SUCCESS.md
    echo -e "${GREEN}✓ 临时文档已删除${NC}"
else
    echo -e "${YELLOW}⚠ 临时文档不存在${NC}"
fi
echo ""

# -----------------------------------------------------------------------------
# 第 3 步：交互式处理备份文件
# -----------------------------------------------------------------------------
# 查找所有 .bak 备份文件，询问用户是否删除
echo "[3/3] 备份文件处理..."
BAK_FILES=$(find . -name "*.bak" 2>/dev/null)
if [ -n "$BAK_FILES" ]; then
    echo "找到以下备份文件:"
    echo "$BAK_FILES"
    echo ""
    # read -p: 显示提示信息
    # -n 1: 只读取一个字符
    # -r: 不处理反斜杠转义
    read -p "是否删除备份文件? (y/N): " -n 1 -r
    echo ""
    # 正则匹配：检查用户输入是否为 y 或 Y
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        find . -name "*.bak" -delete
        echo -e "${GREEN}✓ 备份文件已删除${NC}"
    else
        echo -e "${YELLOW}⚠ 保留备份文件${NC}"
    fi
else
    echo -e "${YELLOW}⚠ 没有找到备份文件${NC}"
fi
echo ""

# -----------------------------------------------------------------------------
# 清理完成
# -----------------------------------------------------------------------------
echo -e "${GREEN}清理完成！${NC}"
