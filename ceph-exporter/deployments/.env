# =============================================================================
# ceph-exporter 部署环境变量配置
# =============================================================================
# 本文件定义 docker-compose.yml 中使用的环境变量默认值。
# 可根据实际环境修改，docker-compose 会自动加载同目录下的 .env 文件。
#
# 使用方式:
#   1. 复制本文件并根据环境修改: cp .env .env.local
#   2. 使用自定义环境文件启动: docker-compose --env-file .env.local up -d
# =============================================================================

# -----------------------------------------------------------------------------
# 版本信息
# -----------------------------------------------------------------------------
VERSION=dev
BUILD_TIME=unknown
GIT_COMMIT=unknown

# -----------------------------------------------------------------------------
# ceph-exporter 配置
# -----------------------------------------------------------------------------
# 宿主机暴露端口
CEPH_EXPORTER_PORT=9128
# Ceph 配置目录（宿主机路径，挂载到容器内 /etc/ceph）
CEPH_CONFIG_DIR=/etc/ceph
# Ceph 连接参数
CEPH_CONFIG=/etc/ceph/ceph.conf
CEPH_USER=admin
CEPH_CLUSTER=ceph
# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
# 资源限制
EXPORTER_CPU_LIMIT=1.0
EXPORTER_MEM_LIMIT=512M

# -----------------------------------------------------------------------------
# Prometheus 配置
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_CPU_LIMIT=2.0
PROMETHEUS_MEM_LIMIT=2G

# -----------------------------------------------------------------------------
# Grafana 配置
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS=false
GRAFANA_PLUGINS=
GRAFANA_CPU_LIMIT=1.0
GRAFANA_MEM_LIMIT=512M

# -----------------------------------------------------------------------------
# Alertmanager 配置
# -----------------------------------------------------------------------------
ALERTMANAGER_PORT=9093
ALERTMANAGER_CPU_LIMIT=0.5
ALERTMANAGER_MEM_LIMIT=256M
