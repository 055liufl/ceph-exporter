# =============================================================================
# ceph-exporter 部署环境变量配置（参考文档）
# =============================================================================
# 注意: 当前 docker-compose*.yml 文件中未使用 ${VAR} 变量引用，
# 因此修改本文件不会影响实际部署。端口和资源限制直接在 docker-compose 文件中配置。
# 本文件仅作为配置参考和文档用途。
#
# 如需自定义配置，请直接修改对应的 docker-compose*.yml 文件。
# =============================================================================

# -----------------------------------------------------------------------------
# 版本信息
# -----------------------------------------------------------------------------
VERSION=dev
BUILD_TIME=unknown
GIT_COMMIT=unknown

# -----------------------------------------------------------------------------
# ceph-exporter 配置
# -----------------------------------------------------------------------------
# 宿主机暴露端口
CEPH_EXPORTER_PORT=9128
# Ceph 配置目录（宿主机路径，挂载到容器内 /etc/ceph）
CEPH_CONFIG_DIR=/etc/ceph
# Ceph 连接参数
CEPH_CONFIG=/etc/ceph/ceph.conf
CEPH_USER=admin
CEPH_CLUSTER=ceph
# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
# 注意: 以下内存限制为参考值，实际限制在 docker-compose*.yml 中配置
# 资源限制
EXPORTER_CPU_LIMIT=1.0
EXPORTER_MEM_LIMIT=128m

# -----------------------------------------------------------------------------
# Prometheus 配置
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_CPU_LIMIT=2.0
PROMETHEUS_MEM_LIMIT=512m

# -----------------------------------------------------------------------------
# Grafana 配置
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS=false
GRAFANA_PLUGINS=
GRAFANA_CPU_LIMIT=1.0
GRAFANA_MEM_LIMIT=256m

# -----------------------------------------------------------------------------
# Alertmanager 配置
# -----------------------------------------------------------------------------
ALERTMANAGER_PORT=9093
ALERTMANAGER_CPU_LIMIT=0.5
ALERTMANAGER_MEM_LIMIT=128m
