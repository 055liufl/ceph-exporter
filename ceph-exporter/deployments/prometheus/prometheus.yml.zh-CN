# =============================================================================
# Prometheus 配置文件
# =============================================================================
# 本文件定义 Prometheus 的全局配置、告警规则、alertmanager 以及抓取目标。
#
# 架构说明：
#   Prometheus 定期从 ceph-exporter 的 /metrics 端点拉取指标数据，
#   根据 alert_rules.yml 中定义的规则评估告警条件，
#   并将触发的告警发送到 Alertmanager 进行分组和通知。
#
# 抓取目标：
#   - ceph-exporter:9128/metrics  Ceph 集群指标
#   - localhost:9090/metrics      Prometheus 自身指标
# =============================================================================

# -----------------------------------------------------------------------------
# 全局配置
# -----------------------------------------------------------------------------
global:
  # 默认抓取间隔（每 15 秒从目标拉取一次指标）
  scrape_interval: 15s

  # 默认抓取超时时间（单次抓取的最大等待时间）
  scrape_timeout: 10s

  # 告警规则评估间隔（每 15 秒评估一次告警条件）
  evaluation_interval: 15s

  # 外部标签（附加到所有时间序列数据和告警上，用于区分不同的 Prometheus 实例）
  external_labels:
    cluster: "ceph-monitor"          # 监控集群标识
    environment: "production"        # 环境标识

# -----------------------------------------------------------------------------
# 告警规则文件
# -----------------------------------------------------------------------------
# Prometheus 会加载以下文件中定义的告警规则，并根据 evaluation_interval 定期评估
rule_files:
  - "/etc/prometheus/alert_rules.yml"

# -----------------------------------------------------------------------------
# Alertmanager 配置
# -----------------------------------------------------------------------------
# 定义 Prometheus 应该将告警发送到哪些 Alertmanager 实例
alerting:
  alertmanagers:
    - static_configs:
        - targets:
            # Alertmanager 地址（使用 Docker 服务名解析）
            - "alertmanager:9093"
      # 发送告警超时时间
      timeout: 10s

# -----------------------------------------------------------------------------
# 抓取配置
# -----------------------------------------------------------------------------
# 定义 Prometheus 应该从哪些目标抓取指标
scrape_configs:
  # ---------------------------------------------------------------------------
  # Prometheus 自监控
  # ---------------------------------------------------------------------------
  # 采集 Prometheus 自身的运行指标（内存、CPU、抓取延迟等）
  # 用于监控 Prometheus 本身
  - job_name: "prometheus"

    scrape_interval: 15s

    static_configs:
      - targets:
          - "localhost:9090"
        labels:
          service: "prometheus"

  # ---------------------------------------------------------------------------
  # Ceph Exporter 监控
  # ---------------------------------------------------------------------------
  # 从 ceph-exporter 采集 Ceph 集群监控指标
  # 包括：集群容量、OSD 状态、存储池统计、Monitor 状态、健康检查等
  - job_name: "ceph-exporter"

    # 抓取间隔（覆盖全局默认值，Ceph 指标变化较慢，15s 足够）
    scrape_interval: 15s

    # 抓取超时时间（Ceph 命令可能较慢，给予充足时间）
    scrape_timeout: 10s

    # 指标路径（默认 /metrics）
    metrics_path: /metrics

    # 静态目标配置
    static_configs:
      - targets:
          # ceph-exporter 服务地址（Docker 服务名:端口）
          - "ceph-exporter:9128"
        # 附加标签（用于在 Grafana 中过滤和分组）
        labels:
          service: "ceph-exporter"
          component: "ceph"

  # ---------------------------------------------------------------------------
  # Alertmanager 监控
  # ---------------------------------------------------------------------------
  # 采集 Alertmanager 运行指标
  - job_name: "alertmanager"

    scrape_interval: 30s

    static_configs:
      - targets:
          - "alertmanager:9093"
        labels:
          service: "alertmanager"

  # ---------------------------------------------------------------------------
  # Grafana 监控
  # ---------------------------------------------------------------------------
  # 采集 Grafana 运行指标（仪表盘数量、用户数、API 性能等）
  # 用于监控 Grafana 本身
  - job_name: "grafana"

    scrape_interval: 30s

    scrape_timeout: 10s

    # Grafana 指标端点
    metrics_path: /metrics

    static_configs:
      - targets:
          # Grafana 服务地址（Docker 服务名:端口）
          - "grafana:3000"
        labels:
          service: "grafana"
          component: "monitoring"
