# =============================================================================
# 集成测试 Docker Compose 配置 - 详细中文注释版本
# =============================================================================
#
# 【文件用途】
#   本配置文件用于集成测试环境,包含完整的测试栈
#   提供独立的 Ceph Demo 集群和监控组件用于自动化测试
#
# 【包含组件】
#   1. ceph-demo: 单节点 Ceph 测试集群
#      - 提供真实的 Ceph 环境用于测试
#      - 独立于生产环境
#
#   2. ceph-exporter: 被测试的指标导出器
#      - 从 Ceph Demo 收集指标
#      - 验证指标导出功能
#
#   3. prometheus: 时序数据库
#      - 抓取和存储测试指标
#      - 验证指标格式和内容
#
#   4. grafana: 可视化平台
#      - 验证仪表板配置
#      - 测试数据展示
#
# 【资源需求】
#   最小配置:
#     - 内存: 2-3GB
#     - CPU: 2 核心
#     - 磁盘: 10GB 可用空间
#
# 【使用场景】
#   ✓ 自动化集成测试
#   ✓ CI/CD 流水线测试
#   ✓ 功能验证和回归测试
#   ✓ 开发环境快速验证
#   ✗ 不适合生产环境
#
# 【测试流程】
#   1. 启动 Ceph Demo 集群
#   2. 等待 Ceph 集群就绪
#   3. 启动 ceph-exporter
#   4. 验证指标导出
#   5. 启动 Prometheus 和 Grafana
#   6. 执行测试用例
#   7. 清理测试环境
#
# 【使用方法】
#   启动测试环境:
#     docker-compose -f docker-compose-integration-test.yml up -d
#
#   等待服务就绪:
#     docker-compose -f docker-compose-integration-test.yml ps
#
#   查看测试日志:
#     docker-compose -f docker-compose-integration-test.yml logs -f
#
#   执行测试:
#     # 测试 ceph-exporter 健康检查
#     curl http://localhost:9128/health
#
#     # 测试指标导出
#     curl http://localhost:9128/metrics
#
#     # 测试 Prometheus 抓取
#     curl http://localhost:9090/api/v1/targets
#
#   清理测试环境:
#     docker-compose -f docker-compose-integration-test.yml down -v
#
# 【访问地址】
#   - Ceph Dashboard: http://localhost:8080
#   - ceph-exporter: http://localhost:9128/metrics
#   - Prometheus: http://localhost:9090
#   - Grafana: http://localhost:3000 (admin/admin)
#
# 【注意事项】
#   1. 测试环境使用独立的容器名称 (带 -test 后缀)
#   2. 测试环境使用独立的数据卷
#   3. 测试完成后建议清理数据卷 (docker-compose down -v)
#   4. 不要在生产环境使用此配置
#
# =============================================================================

version: "2.1"

# =============================================================================
# 服务定义区域
# =============================================================================
services:

  # ===========================================================================
  # Ceph Demo 服务 - 测试用单节点 Ceph 集群
  # ===========================================================================
  # 【服务功能】
  #   为集成测试提供真实的 Ceph 存储集群环境
  #
  # 【测试特性】
  #   - 快速启动 (约 30-60 秒)
  #   - 完整功能 (MON, OSD, MDS, RGW)
  #   - 独立环境 (不影响其他服务)
  #   - 可重复性 (每次启动状态一致)
  #
  ceph-demo:
    # -------------------------------------------------------------------------
    # 镜像配置
    # -------------------------------------------------------------------------
    # image: 使用 ceph/demo 镜像 (注意不是 ceph/daemon)
    # latest-nautilus: Nautilus 版本 (Ceph 14.x)
    # demo 镜像特点:
    #   - 专为演示和测试设计
    #   - 启动速度更快
    #   - 配置更简单
    image: ceph/demo:latest-nautilus

    # -------------------------------------------------------------------------
    # 容器标识
    # -------------------------------------------------------------------------
    # container_name: 使用 -test 后缀区分测试环境
    # 避免与开发环境或其他环境的容器名称冲突
    container_name: ceph-demo-test

    # hostname: Ceph 集群内部主机名
    # 保持简单,不使用 -test 后缀
    hostname: ceph-demo

    # -------------------------------------------------------------------------
    # 环境变量配置
    # -------------------------------------------------------------------------
    environment:
      # MON_IP: Monitor 服务 IP 地址
      # 172.20.0.10: 在测试网络中的固定 IP
      # 必须与下方 networks 配置一致
      - MON_IP=172.20.0.10

      # CEPH_PUBLIC_NETWORK: Ceph 公共网络
      # 172.20.0.0/16: 测试网络的地址范围
      - CEPH_PUBLIC_NETWORK=172.20.0.0/16

      # CEPH_DEMO_UID: RGW 测试用户 ID
      # 用于测试对象存储功能
      - CEPH_DEMO_UID=demo

      # CEPH_DEMO_ACCESS_KEY: RGW 访问密钥
      # 测试环境使用简单密钥
      - CEPH_DEMO_ACCESS_KEY=demo_access_key

      # CEPH_DEMO_SECRET_KEY: RGW 秘密密钥
      # 测试环境使用简单密钥
      - CEPH_DEMO_SECRET_KEY=demo_secret_key

      # RGW_CIVETWEB_PORT: RGW HTTP 端口
      # 8080: Ceph Dashboard 和 RGW API 端口
      - RGW_CIVETWEB_PORT=8080

    # -------------------------------------------------------------------------
    # 端口映射
    # -------------------------------------------------------------------------
    ports:
      # Ceph Dashboard / RGW 端口
      # 用于手动验证 Ceph 集群状态
      - "8080:8080"

    # -------------------------------------------------------------------------
    # 网络配置
    # -------------------------------------------------------------------------
    networks:
      test-network:
        # 固定 IP 地址
        # 确保 Monitor 地址稳定
        ipv4_address: 172.20.0.10

    # -------------------------------------------------------------------------
    # 数据卷挂载
    # -------------------------------------------------------------------------
    volumes:
      # Ceph 数据卷 (测试专用)
      # 存储 OSD 数据、Mon 数据等
      # 测试完成后可以删除
      - ceph-demo-data:/var/lib/ceph

      # Ceph 配置卷 (测试专用)
      # 存储配置文件和密钥
      # 需要共享给 ceph-exporter
      - ceph-demo-config:/etc/ceph

    # -------------------------------------------------------------------------
    # 特权模式
    # -------------------------------------------------------------------------
    # privileged: true
    # Ceph 需要特权模式管理存储设备
    privileged: true

    # -------------------------------------------------------------------------
    # 重启策略
    # -------------------------------------------------------------------------
    # restart: unless-stopped
    # 测试期间自动重启失败的容器
    restart: unless-stopped

    # -------------------------------------------------------------------------
    # 资源限制
    # -------------------------------------------------------------------------
    # mem_limit: 1024MB (1GB)
    # Ceph Demo 需要较多内存
    # 如果内存不足,可能导致:
    #   - OSD 启动失败
    #   - 集群状态异常
    #   - 测试失败
    mem_limit: 1024m

  # ===========================================================================
  # ceph-exporter 服务 - 被测试的指标导出器
  # ===========================================================================
  # 【测试目标】
  #   - 验证指标导出功能
  #   - 验证 Ceph 连接
  #   - 验证健康检查
  #   - 验证配置加载
  #
  ceph-exporter:
    # -------------------------------------------------------------------------
    # 构建配置
    # -------------------------------------------------------------------------
    # build: 从源代码构建测试镜像
    build:
      # context: 构建上下文 (项目根目录)
      context: ..

      # dockerfile: Dockerfile 路径
      dockerfile: Dockerfile

    # image: 测试镜像标签
    # 使用 :test 标签区分测试版本
    image: ceph-exporter:test

    # container_name: 测试容器名称
    container_name: ceph-exporter-test

    # -------------------------------------------------------------------------
    # 端口映射
    # -------------------------------------------------------------------------
    ports:
      # ceph-exporter HTTP 端口
      # 9128: 标准端口
      # 端点:
      #   - /metrics: Prometheus 指标
      #   - /health: 健康检查
      - "9128:9128"

    # -------------------------------------------------------------------------
    # 数据卷挂载
    # -------------------------------------------------------------------------
    volumes:
      # Ceph 配置目录 (只读)
      # 从 ceph-demo 容器共享
      # 包含 ceph.conf 和 keyring 文件
      - ceph-demo-config:/etc/ceph:ro

      # ceph-exporter 配置文件 (只读)
      # 测试配置文件
      - ../configs/ceph-exporter.yaml:/etc/ceph-exporter/ceph-exporter.yaml:ro

    # -------------------------------------------------------------------------
    # 环境变量配置
    # -------------------------------------------------------------------------
    environment:
      # CEPH_CONFIG: Ceph 配置文件路径
      - CEPH_CONFIG=/etc/ceph/ceph.conf

      # CEPH_USER: Ceph 用户名
      # admin: 管理员用户,拥有完全权限
      - CEPH_USER=admin

      # CEPH_CLUSTER: Ceph 集群名称
      # ceph: 默认集群名称
      - CEPH_CLUSTER=ceph

      # LOG_LEVEL: 日志级别
      # info: 标准日志级别
      # 测试时可以改为 debug 获取更多信息
      - LOG_LEVEL=info

      # LOG_FORMAT: 日志格式
      # json: JSON 格式,便于解析和分析
      - LOG_FORMAT=json

    # -------------------------------------------------------------------------
    # 网络配置
    # -------------------------------------------------------------------------
    networks:
      # 连接到测试网络
      # 与 ceph-demo 在同一网络
      - test-network

    # -------------------------------------------------------------------------
    # 服务依赖
    # -------------------------------------------------------------------------
    # depends_on: 依赖 ceph-demo
    # 确保 Ceph 集群先启动
    depends_on:
      - ceph-demo

    # -------------------------------------------------------------------------
    # 健康检查配置
    # -------------------------------------------------------------------------
    healthcheck:
      # test: 健康检查命令
      # 访问 /health 端点
      test: ["CMD", "wget", "-qO-", "http://localhost:9128/health"]

      # interval: 检查间隔
      # 15 秒检查一次
      interval: 15s

      # timeout: 检查超时
      # 5 秒超时
      timeout: 5s

      # retries: 失败重试次数
      # 5 次失败后标记为 unhealthy
      # 测试环境增加重试次数,因为 Ceph 启动较慢
      retries: 5

    restart: unless-stopped

    # -------------------------------------------------------------------------
    # 资源限制
    # -------------------------------------------------------------------------
    # mem_limit: 128MB
    # ceph-exporter 内存使用较少
    mem_limit: 128m

  # ===========================================================================
  # Prometheus 服务 - 时序数据库 (测试用)
  # ===========================================================================
  # 【测试目标】
  #   - 验证指标抓取
  #   - 验证指标格式
  #   - 验证数据存储
  #
  prometheus:
    # -------------------------------------------------------------------------
    # 镜像配置
    # -------------------------------------------------------------------------
    image: prom/prometheus:v2.51.0

    # container_name: 测试容器名称
    container_name: prometheus-test

    # -------------------------------------------------------------------------
    # 端口映射
    # -------------------------------------------------------------------------
    ports:
      # Prometheus Web UI 端口
      - "9090:9090"

    # -------------------------------------------------------------------------
    # 数据卷挂载
    # -------------------------------------------------------------------------
    volumes:
      # Prometheus 配置文件 (只读)
      # 使用标准配置文件
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro

      # Prometheus 数据卷 (测试专用)
      # 存储测试期间的时序数据
      - prometheus-test-data:/prometheus

    # -------------------------------------------------------------------------
    # 启动命令
    # -------------------------------------------------------------------------
    command:
      # --config.file: 配置文件路径
      - "--config.file=/etc/prometheus/prometheus.yml"

      # --storage.tsdb.path: 数据存储路径
      - "--storage.tsdb.path=/prometheus"

      # --storage.tsdb.retention.time: 数据保留时间
      # 7d: 测试环境保留 7 天
      # 减少磁盘占用
      - "--storage.tsdb.retention.time=7d"

      # --web.enable-lifecycle: 启用生命周期 API
      # 允许动态重载配置
      - "--web.enable-lifecycle"

    # -------------------------------------------------------------------------
    # 网络配置
    # -------------------------------------------------------------------------
    networks:
      - test-network

    # -------------------------------------------------------------------------
    # 服务依赖
    # -------------------------------------------------------------------------
    depends_on:
      - ceph-exporter

    # -------------------------------------------------------------------------
    # 健康检查
    # -------------------------------------------------------------------------
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:9090/-/healthy"]
      interval: 15s
      timeout: 5s
      retries: 3

    restart: unless-stopped

    # -------------------------------------------------------------------------
    # 资源限制
    # -------------------------------------------------------------------------
    mem_limit: 512m

  # ===========================================================================
  # Grafana 服务 - 可视化平台 (测试用)
  # ===========================================================================
  # 【测试目标】
  #   - 验证仪表板配置
  #   - 验证数据源连接
  #   - 验证数据展示
  #
  grafana:
    # -------------------------------------------------------------------------
    # 镜像配置
    # -------------------------------------------------------------------------
    image: grafana/grafana:10.4.0

    # container_name: 测试容器名称
    container_name: grafana-test

    # -------------------------------------------------------------------------
    # 端口映射
    # -------------------------------------------------------------------------
    ports:
      # Grafana Web UI 端口
      - "3000:3000"

    # -------------------------------------------------------------------------
    # 数据卷挂载
    # -------------------------------------------------------------------------
    volumes:
      # Grafana 数据卷 (测试专用)
      - grafana-test-data:/var/lib/grafana

      # 数据源自动配置 (只读)
      - ./grafana/provisioning/datasources:/etc/grafana/provisioning/datasources:ro

      # 仪表板自动配置 (只读)
      - ./grafana/provisioning/dashboards:/etc/grafana/provisioning/dashboards:ro

      # 仪表板 JSON 文件 (只读)
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro

    # -------------------------------------------------------------------------
    # 环境变量配置
    # -------------------------------------------------------------------------
    environment:
      # GF_SECURITY_ADMIN_USER: 管理员用户名
      # 测试环境使用默认账号
      - GF_SECURITY_ADMIN_USER=admin

      # GF_SECURITY_ADMIN_PASSWORD: 管理员密码
      # 测试环境使用简单密码
      - GF_SECURITY_ADMIN_PASSWORD=admin

      # GF_AUTH_ANONYMOUS_ENABLED: 禁用匿名访问
      - GF_AUTH_ANONYMOUS_ENABLED=false

    # -------------------------------------------------------------------------
    # 网络配置
    # -------------------------------------------------------------------------
    networks:
      - test-network

    # -------------------------------------------------------------------------
    # 服务依赖
    # -------------------------------------------------------------------------
    depends_on:
      - prometheus

    # -------------------------------------------------------------------------
    # 健康检查
    # -------------------------------------------------------------------------
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/api/health"]
      interval: 15s
      timeout: 5s
      retries: 3

    restart: unless-stopped

    # -------------------------------------------------------------------------
    # 资源限制
    # -------------------------------------------------------------------------
    mem_limit: 256m

# =============================================================================
# 网络配置区域
# =============================================================================
networks:
  # ---------------------------------------------------------------------------
  # test-network: 测试环境专用网络
  # ---------------------------------------------------------------------------
  # 用途:
  #   - 隔离测试环境
  #   - 提供固定 IP 地址
  #   - 支持服务发现
  #
  # 特点:
  #   - 独立于其他环境
  #   - 使用独立的 IP 地址段
  #   - 测试完成后可以删除
  test-network:
    # driver: bridge 桥接网络
    driver: bridge

    # ipam: IP 地址管理
    ipam:
      config:
        # subnet: 测试网络子网
        # 172.20.0.0/16: 提供足够的 IP 地址
        # 与其他环境使用不同的地址段
        - subnet: 172.20.0.0/16

# =============================================================================
# 数据卷配置区域
# =============================================================================
volumes:
  # ---------------------------------------------------------------------------
  # 测试环境数据卷
  # ---------------------------------------------------------------------------
  # 注意: 所有数据卷都是测试专用
  # 测试完成后建议删除: docker-compose down -v
  #
  # ceph-demo-data: Ceph 测试数据
  ceph-demo-data:

  # ceph-demo-config: Ceph 测试配置
  # 重要: 需要共享给 ceph-exporter
  ceph-demo-config:

  # prometheus-test-data: Prometheus 测试数据
  prometheus-test-data:

  # grafana-test-data: Grafana 测试数据
  grafana-test-data:

# =============================================================================
# 配置文件结束
# =============================================================================
#
# 【测试用例示例】
#
# 1. 健康检查测试:
#    curl -f http://localhost:9128/health || exit 1
#
# 2. 指标导出测试:
#    curl http://localhost:9128/metrics | grep "ceph_health_status"
#
# 3. Prometheus 抓取测试:
#    curl http://localhost:9090/api/v1/targets | jq '.data.activeTargets[] | select(.labels.job=="ceph-exporter")'
#
# 4. 数据查询测试:
#    curl 'http://localhost:9090/api/v1/query?query=up{job="ceph-exporter"}' | jq '.data.result[0].value[1]'
#
# 5. Grafana 数据源测试:
#    curl -u admin:admin http://localhost:3000/api/datasources | jq '.[0].name'
#
# 【自动化测试脚本】
#
# #!/bin/bash
# set -e
#
# echo "启动测试环境..."
# docker-compose -f docker-compose-integration-test.yml up -d
#
# echo "等待服务就绪..."
# sleep 60
#
# echo "测试 ceph-exporter 健康检查..."
# curl -f http://localhost:9128/health
#
# echo "测试指标导出..."
# curl -s http://localhost:9128/metrics | grep -q "ceph_health_status"
#
# echo "测试 Prometheus 抓取..."
# curl -s http://localhost:9090/api/v1/targets | jq -e '.data.activeTargets[] | select(.labels.job=="ceph-exporter") | .health == "up"'
#
# echo "所有测试通过!"
#
# echo "清理测试环境..."
# docker-compose -f docker-compose-integration-test.yml down -v
#
# =============================================================================
