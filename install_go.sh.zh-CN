#!/bin/bash
# =============================================================================
# Go 环境安装脚本 - 详细中文注释版本
# =============================================================================
# 功能说明：
#   自动安装 Go 开发环境和相关工具
#
# 主要功能：
#   1. 安装 Go SDK（根据权限选择安装位置）
#   2. 配置环境变量（PATH、GOPATH）
#   3. 配置 Go 代理（加速国内下载）
#   4. 安装常用 Go 工具（goimports、golangci-lint）
#
# 使用方法：
#   ./install_go.sh
#
# 前置条件：
#   - 已下载 Go 安装包到 /tmp/go1.21.6.linux-amd64.tar.gz
#   - 如果没有，请先运行：
#     wget https://golang.google.cn/dl/go1.21.6.linux-amd64.tar.gz -O /tmp/go1.21.6.linux-amd64.tar.gz
#
# 安装位置：
#   - 有 sudo 权限：安装到 /usr/local/go（系统级）
#   - 无 sudo 权限：安装到 ~/go-sdk/go（用户级）
#
# 注意事项：
#   - 安装后需要运行 source ~/.bashrc 使环境变量生效
#   - 或者重新登录终端
# =============================================================================

# -----------------------------------------------------------------------------
# Bash 严格模式设置
# -----------------------------------------------------------------------------
# set -e: 遇到错误立即退出
set -e

# -----------------------------------------------------------------------------
# 安装 Go SDK
# -----------------------------------------------------------------------------

echo "=== 安装 Go 环境 ==="

# 检查是否有 sudo 权限
# 说明：
#   - sudo -n true: 尝试以 sudo 运行 true 命令
#   - -n: 非交互模式，不提示输入密码
#   - 2>/dev/null: 忽略错误输出
if sudo -n true 2>/dev/null; then
    # 有 sudo 权限，安装到系统目录
    echo "检测到 sudo 权限,安装到 /usr/local"

    # tar -C: 指定解压目录
    # -x: 解压
    # -z: 使用 gzip 解压
    # -f: 指定文件
    sudo tar -C /usr/local -xzf /tmp/go1.21.6.linux-amd64.tar.gz

    # 设置 Go 根目录
    GO_ROOT="/usr/local/go"
else
    # 无 sudo 权限，安装到用户目录
    echo "无 sudo 权限,安装到用户目录"

    # 创建用户级 SDK 目录
    # -p: 如果父目录不存在，一并创建
    mkdir -p ~/go-sdk

    # 解压到用户目录
    tar -C ~/go-sdk -xzf /tmp/go1.21.6.linux-amd64.tar.gz

    # 设置 Go 根目录（使用 $HOME 变量）
    GO_ROOT="$HOME/go-sdk/go"
fi

# -----------------------------------------------------------------------------
# 配置环境变量
# -----------------------------------------------------------------------------

echo "配置环境变量..."

# 将环境变量配置追加到 ~/.bashrc
# cat >> file << EOF: Here Document，追加多行内容到文件
# \$PATH: 转义 $，避免在写入时展开变量
cat >> ~/.bashrc << EOF

# Go 环境配置
# 添加 Go 二进制文件目录到 PATH
export PATH=\$PATH:$GO_ROOT/bin

# GOPATH: Go 工作空间目录
# 用于存放下载的包和编译的二进制文件
export GOPATH=\$HOME/go

# 添加 GOPATH/bin 到 PATH
# 这样可以直接运行 go install 安装的工具
export PATH=\$PATH:\$GOPATH/bin
EOF

# -----------------------------------------------------------------------------
# 立即生效环境变量
# -----------------------------------------------------------------------------
# 说明：
#   - 上面的配置只在新终端生效
#   - 这里手动设置，让当前脚本可以使用

# 立即生效
export PATH=$PATH:$GO_ROOT/bin
export GOPATH=$HOME/go
export PATH=$PATH:$GOPATH/bin

# -----------------------------------------------------------------------------
# 验证 Go 安装
# -----------------------------------------------------------------------------

echo "验证 Go 安装..."
# 显示 Go 版本
go version

# -----------------------------------------------------------------------------
# 配置 Go 代理
# -----------------------------------------------------------------------------
# 说明：
#   - 国内访问 Go 官方模块代理速度慢
#   - 使用 goproxy.cn 加速下载
#   - go env -w: 写入 Go 环境配置

# 配置 Go 代理 (加速下载)
go env -w GOPROXY=https://goproxy.cn,direct

# -----------------------------------------------------------------------------
# 安装 Go 工具
# -----------------------------------------------------------------------------

# 安装 goimports
# 说明：
#   - goimports: 自动管理 import 语句并格式化代码
#   - go install: 下载、编译并安装 Go 程序
#   - @latest: 安装最新版本
echo "安装 goimports..."
go install golang.org/x/tools/cmd/goimports@latest

# 安装 golangci-lint
# 说明：
#   - golangci-lint: Go 代码静态分析工具集合
#   - 包含多种 linter（如 gofmt、govet、staticcheck 等）
#   - 使用官方安装脚本
echo "安装 golangci-lint..."
# curl -sSfL: 静默下载，失败时返回错误
# sh -s -- -b: 执行脚本，-b 指定安装目录
curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b $(go env GOPATH)/bin

# -----------------------------------------------------------------------------
# 验证工具安装
# -----------------------------------------------------------------------------

echo "验证工具安装..."

# which: 显示命令的完整路径
# 验证所有工具都已安装
which go gofmt goimports golangci-lint

# 显示版本信息
go version

# goimports -h: 显示帮助信息
# > /dev/null: 丢弃输出
# &&: 如果前面的命令成功，执行后面的命令
goimports -h > /dev/null && echo "✓ goimports 安装成功"

# 显示 golangci-lint 版本
golangci-lint version

# -----------------------------------------------------------------------------
# 完成提示
# -----------------------------------------------------------------------------

echo "=== Go 环境安装完成 ==="
echo "请运行: source ~/.bashrc"
echo "然后执行: pre-commit run --all-files"
